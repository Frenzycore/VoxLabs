---
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 flex justify-between items-start sm:items-center px-4 sm:px-8 py-3"
>
  <span class="flex items-center gap-2" style="color: var(--c-accent)">
    <svg width="20" height="20" viewBox="0 0 100 100">
      <path d="M20 20 L50 66 L80 20" fill="none" stroke="var(--c-accent)" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>

  <div class="flex flex-col-reverse sm:flex-row items-center gap-2">
    <a
      href="https://github.com/Frenzycore/VoxLabs"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="View source on GitHub"
      class="w-9 h-9 rounded-full flex items-center justify-center transition-transform hover:scale-110"
      style="color: var(--c-text-soft)"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-1.94c-3.2.7-3.87-1.36-3.87-1.36-.53-1.33-1.29-1.69-1.29-1.69-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A10.52 10.52 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"></path>
      </svg>
    </a>

    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle light/dark theme"
      class="w-9 h-9 rounded-full flex items-center justify-center transition-transform hover:scale-110"
      style="color: var(--c-text-soft)"
    >
      <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg id="icon-sun" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
      </svg>
    </button>
  </div>
</nav>

<script src="../scripts/theme-toggle.js"></script>
